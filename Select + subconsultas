-- Bloco 1

SELECT ProductName, Price 
FROM Products 
WHERE Price > (
    SELECT AVG(Price) 
    FROM Products
) LIMIT 15;

SELECT CONCAT(LastName, ', ', FirstName) 
FROM Employees 
WHERE BirthDate < (
    SELECT MAX(BirthDate) 
    FROM Employees
) LIMIT 5;

SELECT ProductName, Price, (
    SELECT AVG(p2.Price) 
    FROM Products p2 
    WHERE p2.CategoryID = p1.CategoryID
) 
FROM Products p1 LIMIT 10;

SELECT CONCAT(CustomerName, ' - ', Country) 
FROM Customers 
WHERE Country = (
    SELECT Country 
    FROM Suppliers 
    WHERE SupplierID = 1
);

SELECT ProductName, Price 
FROM Products 
WHERE (Price * 10) < (
    SELECT MAX(Price) 
    FROM Products
) LIMIT 12;

SELECT CustomerName, CONCAT('Última compra em: ', (
    SELECT MAX(OrderDate) 
    FROM Orders o 
    WHERE o.CustomerID = c.CustomerID
)) 
FROM Customers c LIMIT 8;

SELECT OrderDetailID, Quantity 
FROM OrderDetails 
WHERE Quantity = (
    SELECT MAX(Quantity) 
    FROM OrderDetails
) LIMIT 5;

SELECT CONCAT(ShipperName, ' - ', Phone) 
FROM Shippers 
WHERE ShipperID IN (
    SELECT DISTINCT ShipperID 
    FROM Orders 
    WHERE CustomerID = 4
) LIMIT 3;

SELECT t.ProductName, t.NewPrice 
FROM (
    SELECT ProductName, (Price * 0.80) AS NewPrice 
    FROM Products
) t 
WHERE t.NewPrice > 50 LIMIT 10;

SELECT CONCAT(ProductName, ' (', Unit, ')') 
FROM Products 
WHERE SupplierID = (
    SELECT SupplierID 
    FROM Suppliers 
    WHERE City = 'London'
);

-- Bloco 2

SELECT EmployeeID, COUNT(OrderID) 
FROM Orders 
WHERE OrderID IN (
    SELECT od.OrderID 
    FROM OrderDetails od 
    WHERE od.ProductID = (
        SELECT ProductID 
        FROM Products 
        WHERE ProductName = 'Chais'
    )
) 
GROUP BY EmployeeID;

SELECT City, COUNT(CustomerID) 
FROM Customers 
WHERE City IN (
    SELECT DISTINCT City 
    FROM Suppliers
) 
GROUP BY City LIMIT 5;

SELECT ProductID, COUNT(OrderDetailID) 
FROM OrderDetails 
WHERE ProductID IN (
    SELECT ProductID 
    FROM Products 
    WHERE CategoryID = (
        SELECT CategoryID 
        FROM Categories 
        WHERE CategoryName = 'Beverages'
    )
) 
GROUP BY ProductID;

SELECT IF(t.Total > 50, '> 50', '<= 50') AS Faixa, COUNT(t.OrderID) 
FROM (
    SELECT OrderID, SUM(Quantity) AS Total 
    FROM OrderDetails 
    GROUP BY OrderID
) t 
GROUP BY Faixa;

SELECT c.CategoryName, COUNT(p.ProductID) 
FROM Products p 
JOIN Categories c ON p.CategoryID = c.CategoryID 
WHERE p.Price > (
    SELECT AVG(p2.Price) 
    FROM Products p2 
    WHERE p2.CategoryID = p.CategoryID
) 
GROUP BY c.CategoryName;

SELECT ShipperID, COUNT(OrderID) 
FROM Orders o 
WHERE EXISTS (
    SELECT 1 
    FROM Orders o2 
    WHERE o2.OrderID = o.OrderID 
      AND o2.OrderDate BETWEEN '1996-01-01' AND '1996-12-31'
) 
GROUP BY ShipperID;

SELECT SupplierID, COUNT(ProductID) 
FROM Products 
WHERE SupplierID IN (
    SELECT SupplierID 
    FROM Suppliers 
    WHERE Country IN (
        SELECT DISTINCT Country 
        FROM Customers
    )
) 
GROUP BY SupplierID LIMIT 10;

SELECT Country, (
    SELECT COUNT(o.OrderID) 
    FROM Orders o 
    JOIN Customers cust ON o.CustomerID = cust.CustomerID 
    WHERE cust.Country = c.Country
) 
FROM Customers c 
GROUP BY Country;

SELECT ProductID, SUM(Quantity) AS Total 
FROM OrderDetails 
WHERE ProductID IN (
    SELECT ProductID 
    FROM Products 
    WHERE Price > 20
) 
GROUP BY ProductID 
ORDER BY Total DESC LIMIT 5;

SELECT City, COUNT(CustomerID) 
FROM Customers 
WHERE CustomerID IN (
    SELECT CustomerID 
    FROM Orders 
    GROUP BY CustomerID 
    HAVING COUNT(OrderID) > 3
) 
GROUP BY City;

-- Bloco 3

SELECT EmployeeID, COUNT(OrderID) AS Total 
FROM Orders 
GROUP BY EmployeeID 
HAVING Total > (
    SELECT AVG(Qtd) 
    FROM (
        SELECT COUNT(OrderID) AS Qtd 
        FROM Orders 
        GROUP BY EmployeeID
    ) t
);

SELECT c.CategoryName 
FROM Products p 
JOIN Categories c ON p.CategoryID = c.CategoryID 
GROUP BY c.CategoryName 
HAVING AVG(p.Price) > (
    SELECT AVG(Price) 
    FROM Products
);

SELECT Country, COUNT(CustomerID) 
FROM Customers 
GROUP BY Country 
HAVING COUNT(CustomerID) = (
    SELECT COUNT(CustomerID) 
    FROM Customers 
    WHERE Country = 'USA'
);

SELECT OrderID, SUM(Quantity) 
FROM OrderDetails 
GROUP BY OrderID 
HAVING SUM(Quantity) > (
    SELECT MAX(Quantity) 
    FROM OrderDetails
);

SELECT SupplierID, COUNT(ProductID) AS Total 
FROM Products 
GROUP BY SupplierID 
HAVING Total > ALL (
    SELECT COUNT(p2.ProductID) 
    FROM Products p2 
    JOIN Suppliers s ON p2.SupplierID = s.SupplierID 
    WHERE s.Country = 'UK' 
    GROUP BY p2.SupplierID
);

SELECT CustomerID, COUNT(OrderID) AS Total 
FROM Orders 
GROUP BY CustomerID 
HAVING Total > (
    SELECT COUNT(OrderID) 
    FROM Orders 
    WHERE CustomerID = 1
) LIMIT 5;

SELECT CategoryID, MAX(Price) 
FROM Products 
GROUP BY CategoryID 
HAVING MAX(Price) < (
    SELECT 100
);

SELECT EmployeeID, COUNT(OrderID) 
FROM Orders 
GROUP BY EmployeeID 
HAVING EXISTS (
    SELECT 1 
    FROM Orders 
    WHERE OrderDate = '1996-07-04'
);

SELECT ProductID, SUM(Quantity) AS Total 
FROM OrderDetails 
GROUP BY ProductID 
HAVING Total > (
    SELECT SUM(Quantity) 
    FROM OrderDetails 
    WHERE ProductID = (
        SELECT ProductID 
        FROM Products 
        WHERE ProductName = 'Tofu'
    )
);

SELECT City, COUNT(SupplierID) 
FROM Suppliers 
GROUP BY City 
HAVING COUNT(SupplierID) = (
    SELECT COUNT(ShipperID) 
    FROM Shippers
);

-- Bloco 5

SELECT CONCAT(c.CustomerName, ' (', c.City, ')'), COUNT(o.OrderID) AS Total 
FROM Customers c 
LEFT JOIN Orders o ON c.CustomerID = o.CustomerID 
GROUP BY c.CustomerID, c.CustomerName, c.City 
HAVING Total > (
    SELECT AVG(Qtd) 
    FROM (
        SELECT COUNT(o2.OrderID) AS Qtd 
        FROM Customers c2 
        LEFT JOIN Orders o2 ON c2.CustomerID = o2.CustomerID 
        WHERE c2.City = c.City 
        GROUP BY c2.CustomerID
    ) t
) LIMIT 5;

SELECT CONCAT('Categoria: ', c.CategoryName), COUNT(p.ProductID) 
FROM Products p 
JOIN Categories c ON p.CategoryID = c.CategoryID 
WHERE p.CategoryID IN (
    SELECT DISTINCT CategoryID 
    FROM Products 
    WHERE Price > 50
) 
GROUP BY c.CategoryID, c.CategoryName;

SELECT CONCAT(p.ProductName, ' - Ação Necessária'), t.Total 
FROM (
    SELECT ProductID, SUM(Quantity) AS Total 
    FROM OrderDetails 
    GROUP BY ProductID
) t 
JOIN Products p ON t.ProductID = p.ProductID 
ORDER BY t.Total DESC LIMIT 10;

SELECT SupplierID, COUNT(ProductID) AS Qtd 
FROM Products 
WHERE CategoryID = (
    SELECT CategoryID 
    FROM Categories 
    WHERE CategoryName = 'Condiments'
) 
GROUP BY SupplierID 
HAVING Qtd > 1;

SELECT CONCAT('Novo Preço: ', ROUND(Price * 1.05, 2)) 
FROM Products p 
WHERE EXISTS (
    SELECT 1 
    FROM Suppliers s 
    WHERE s.SupplierID = p.SupplierID 
      AND s.Country IN ('UK','Spain','Sweden','Germany','Italy','Norway','France','Denmark','Netherlands','Finland')
) LIMIT 15;

SELECT CONCAT(YEAR(OrderDate), ' - Total: '), COUNT(OrderID) AS Vol 
FROM Orders 
GROUP BY YEAR(OrderDate) 
HAVING Vol > (
    SELECT COUNT(OrderID) 
    FROM Orders 
    WHERE OrderDate BETWEEN '1997-01-01' AND '1997-12-31'
) LIMIT 3;
