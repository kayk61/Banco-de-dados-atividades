-- 1
SELECT Products.ProductName, Suppliers.SupplierName, Suppliers.Country
FROM Products 
INNER JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID
WHERE Products.CategoryID = 2;

-- 2
SELECT Orders.OrderID, Orders.OrderDate, Shippers.ShipperName
FROM Orders 
INNER JOIN Shippers ON Orders.ShipperID = Shippers.ShipperID;

-- 3
SELECT Products.ProductName, Suppliers.City
FROM Products 
INNER JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID
WHERE Products.Price > 50;

-- 4
SELECT Orders.OrderID, Shippers.ShipperName
FROM Orders 
INNER JOIN Shippers ON Orders.ShipperID = Shippers.ShipperID
WHERE Shippers.ShipperName = 'Speedy Express';

-- 5
SELECT Products.ProductName, Suppliers.SupplierName
FROM Products 
INNER JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID
WHERE Suppliers.Country IN ('Brazil', 'USA');

-- 6
SELECT Orders.OrderID, Orders.OrderDate, Shippers.Phone
FROM Orders 
INNER JOIN Shippers ON Orders.ShipperID = Shippers.ShipperID
WHERE Orders.OrderDate BETWEEN '2023-01-01' AND '2023-12-31';

-- 7
SELECT Suppliers.SupplierName, Products.ProductName
FROM Products 
INNER JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID
WHERE Products.Price BETWEEN 10 AND 20;

-- 8
SELECT Orders.OrderID, Shippers.ShipperName
FROM Orders 
INNER JOIN Shippers ON Orders.ShipperID = Shippers.ShipperID
ORDER BY Shippers.ShipperName ASC;

-- 9
SELECT Suppliers.SupplierName, Products.ProductName
FROM Suppliers 
LEFT JOIN Products ON Suppliers.SupplierID = Products.SupplierID;

-- 10
SELECT Shippers.ShipperName, COUNT(Orders.OrderID)
FROM Shippers 
LEFT JOIN Orders ON Shippers.ShipperID = Orders.ShipperID
GROUP BY Shippers.ShipperName;

-- 11
SELECT Products.ProductName, Suppliers.SupplierName
FROM Products 
RIGHT JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID;

-- 12
SELECT Suppliers.SupplierName, Products.ProductName
FROM Suppliers 
LEFT JOIN Products ON Suppliers.SupplierID = Products.SupplierID
WHERE Suppliers.Country = 'Germany';

-- 13
SELECT Shippers.ShipperName, Orders.OrderID
FROM Orders 
RIGHT JOIN Shippers ON Orders.ShipperID = Shippers.ShipperID;

-- 14
SELECT Products.ProductName, Suppliers.SupplierName, Shippers.ShipperName
FROM OrderDetails 
INNER JOIN Products ON OrderDetails.ProductID = Products.ProductID
INNER JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID
INNER JOIN Orders ON OrderDetails.OrderID = Orders.OrderID
INNER JOIN Shippers ON Orders.ShipperID = Shippers.ShipperID
WHERE OrderDetails.OrderID = 10248;

-- 15
SELECT Suppliers.SupplierName, Suppliers.City, Orders.OrderDate
FROM OrderDetails 
INNER JOIN Products ON OrderDetails.ProductID = Products.ProductID
INNER JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID
INNER JOIN Orders ON OrderDetails.OrderID = Orders.OrderID
INNER JOIN Shippers ON Orders.ShipperID = Shippers.ShipperID
WHERE Shippers.ShipperName = 'United Package';

-- 16
SELECT Suppliers.SupplierName
FROM Suppliers 
LEFT JOIN Products ON Suppliers.SupplierID = Products.SupplierID
LEFT JOIN OrderDetails ON Products.ProductID = OrderDetails.ProductID
WHERE OrderDetails.OrderID IS NULL;

-- 17
SELECT Suppliers.ContactName, Products.ProductName
FROM Products 
INNER JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID
WHERE Products.CategoryID IN (1, 3, 5) AND Suppliers.Country = 'UK';

-- 18
SELECT Suppliers.SupplierName, COUNT(Orders.OrderID)
FROM OrderDetails 
INNER JOIN Products ON OrderDetails.ProductID = Products.ProductID
INNER JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID
INNER JOIN Orders ON OrderDetails.OrderID = Orders.OrderID
GROUP BY Suppliers.SupplierName;

-- 19
SELECT Products.ProductName, Products.CategoryID, Suppliers.SupplierName
FROM Products 
INNER JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID
WHERE Products.Price > (SELECT AVG(Price) FROM Products);

-- 20
SELECT Orders.OrderID, Suppliers.SupplierName, Shippers.ShipperName
FROM OrderDetails 
INNER JOIN Orders ON OrderDetails.OrderID = Orders.OrderID
INNER JOIN Shippers ON Orders.ShipperID = Shippers.ShipperID
INNER JOIN Products ON OrderDetails.ProductID = Products.ProductID
INNER JOIN Suppliers ON Products.SupplierID = Suppliers.SupplierID;







